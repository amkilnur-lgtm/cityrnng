// CITYRNNG — initial schema foundation (Epic 0 / auth baseline).
// Business tables (events, points, rewards) land in later epics.

generator client {
  provider      = "prisma-client-js"
  // `native` covers local dev (whatever host you're on); the linux-musl
  // target is what the production Alpine container needs at runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  blocked
  pending
}

enum SessionStatus {
  active
  revoked
  expired
}

enum EventType {
  regular
  special
  partner
}

enum EventStatus {
  draft
  published
  started
  finished
  cancelled
}

enum SyncProvider {
  strava
}

enum AttendanceStatus {
  pending
  approved
  rejected
}

enum EventInterestStatus {
  going
  cancelled
}

enum AttendanceSource {
  sync
  manual_admin
}

enum CityLocationStatus {
  active
  archived
}

enum RecurrenceRuleStatus {
  active
  paused
}

enum PointAccountStatus {
  active
  blocked
}

enum PointDirection {
  credit
  debit
}

enum PointTransactionStatus {
  posted
  reversed
}

enum PointActorType {
  system
  admin
}

enum PointReasonType {
  signup_bonus
  event_attendance_regular
  event_attendance_special
  event_attendance_partner
  manual_adjustment
  first_run_bonus
  streak_bonus
  milestone_bonus
  returning_user_bonus
  campaign_bonus
  partner_bonus
  reward_redemption
  reversal
}

enum PartnerStatus {
  active
  archived
}

enum RewardStatus {
  active
  archived
}

enum RedemptionStatus {
  active
  used
  expired
  cancelled
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique
  phone     String?    @unique
  status    UserStatus @default(pending)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  profile                  Profile?
  roles                    UserRole[]
  sessions                 Session[]
  createdEvents            Event[]               @relation("EventCreatedBy")
  createdRecurrenceRules   EventRecurrenceRule[] @relation("RecurrenceRuleCreatedBy")
  createdPartners          Partner[]             @relation("PartnerCreatedBy")
  createdRewards           Reward[]              @relation("RewardCreatedBy")
  redemptions              Redemption[]          @relation("RedemptionUser")
  providerAccounts         UserProviderAccount[]
  externalActivities       ExternalActivity[]
  attendances              EventAttendance[]     @relation("AttendanceUser")
  attendanceReviews        EventAttendance[]     @relation("AttendanceReviewer")
  eventInterests           EventInterest[]
  pointAccount             PointAccount?
  pointTransactions        PointTransaction[]    @relation("PointTransactionUser")
  createdPointTransactions PointTransaction[]    @relation("PointTransactionCreatedBy")
  partnerMemberships       PartnerMember[]       @relation("PartnerMemberUser")
  createdPartnerMembers    PartnerMember[]       @relation("PartnerMemberCreatedBy")

  @@map("users")
}

model Profile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  displayName           String    @map("display_name")
  firstName             String?   @map("first_name")
  lastName              String?   @map("last_name")
  city                  String?
  birthDate             DateTime? @map("birth_date") @db.Date
  avatarMediaId         String?   @map("avatar_media_id") @db.Uuid
  instagramHandle       String?   @map("instagram_handle")
  telegramHandle        String?   @map("telegram_handle")
  consentPersonalDataAt DateTime? @map("consent_personal_data_at")
  consentMarketingAt    DateTime? @map("consent_marketing_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique
  name String

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model LoginChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("login_challenges")
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  refreshTokenHash String        @unique @map("refresh_token_hash")
  status           SessionStatus @default(active)
  userAgent        String?       @map("user_agent")
  ipAddress        String?       @map("ip_address")
  expiresAt        DateTime      @map("expires_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  revokedAt        DateTime?     @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Event {
  id                    String      @id @default(uuid()) @db.Uuid
  title                 String
  slug                  String      @unique
  description           String?
  type                  EventType   @default(regular)
  status                EventStatus @default(draft)
  startsAt              DateTime    @map("starts_at")
  endsAt                DateTime    @map("ends_at")
  locationName          String?     @map("location_name")
  locationAddress       String?     @map("location_address")
  locationLat           Float?      @map("location_lat")
  locationLng           Float?      @map("location_lng")
  capacity              Int?
  registrationOpenAt    DateTime?   @map("registration_open_at")
  registrationCloseAt   DateTime?   @map("registration_close_at")
  isPointsEligible      Boolean     @default(false) @map("is_points_eligible")
  basePointsAward       Int         @default(0) @map("base_points_award")
  createdById           String      @map("created_by") @db.Uuid
  /// When this event is an override of a recurring rule occurrence.
  recurrenceRuleId      String?     @map("recurrence_rule_id") @db.Uuid
  /// The materialized rule date this event replaces (matched on the calendar day).
  overridesOccurrenceAt DateTime?   @map("overrides_occurrence_at") @db.Date
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  createdBy      User                 @relation("EventCreatedBy", fields: [createdById], references: [id])
  recurrenceRule EventRecurrenceRule? @relation("RuleOverrides", fields: [recurrenceRuleId], references: [id])
  syncRule       EventSyncRule?
  attendances    EventAttendance[]

  @@unique([recurrenceRuleId, overridesOccurrenceAt], map: "uq_event_overrides_per_rule_date")
  @@index([status, startsAt])
  @@index([type])
  @@map("events")
}

// Defines a recurring schedule (e.g. "every Wednesday 19:30, all 3 city
// locations, regular type, points-eligible"). Materialized on demand by
// EventOccurrenceService — no DB row per occurrence unless an override
// Event explicitly replaces it.
model EventRecurrenceRule {
  id               String               @id @default(uuid()) @db.Uuid
  title            String
  type             EventType            @default(regular)
  status           RecurrenceRuleStatus @default(active)
  /// 0 = Sunday, 1 = Monday, ... 6 = Saturday (matches JS Date.getDay).
  dayOfWeek        Int                  @map("day_of_week")
  /// "HH:MM" 24h string in the club's timezone.
  timeOfDay        String               @map("time_of_day")
  durationMinutes  Int                  @map("duration_minutes")
  isPointsEligible Boolean              @default(true) @map("is_points_eligible")
  basePointsAward  Int                  @default(0) @map("base_points_award")
  /// Rule kicks in from this date (inclusive).
  startsFromDate   DateTime             @map("starts_from_date") @db.Date
  /// Optional sunset — rule stops generating occurrences after this date.
  endsAtDate       DateTime?            @map("ends_at_date") @db.Date
  createdById      String               @map("created_by") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  createdBy        User                          @relation("RecurrenceRuleCreatedBy", fields: [createdById], references: [id])
  locations        EventRecurrenceRuleLocation[]
  overridingEvents Event[]                       @relation("RuleOverrides")

  @@index([status, dayOfWeek])
  @@map("event_recurrence_rules")
}

model EventRecurrenceRuleLocation {
  ruleId     String   @map("rule_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  rule     EventRecurrenceRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  location CityLocation        @relation("CityLocationRecurrenceRules", fields: [locationId], references: [id], onDelete: Cascade)

  @@id([ruleId, locationId])
  @@map("event_recurrence_rule_locations")
}

model EventSyncRule {
  id                   String       @id @default(uuid()) @db.Uuid
  eventId              String       @unique @map("event_id") @db.Uuid
  provider             SyncProvider @default(strava)
  activityType         String?      @map("activity_type")
  minDistanceMeters    Int?         @map("min_distance_meters")
  maxDistanceMeters    Int?         @map("max_distance_meters")
  minDurationSeconds   Int?         @map("min_duration_seconds")
  maxDurationSeconds   Int?         @map("max_duration_seconds")
  windowStartsAt       DateTime     @map("window_starts_at")
  windowEndsAt         DateTime     @map("window_ends_at")
  geofenceLat          Float?       @map("geofence_lat")
  geofenceLng          Float?       @map("geofence_lng")
  geofenceRadiusMeters Int?         @map("geofence_radius_meters")
  autoApprove          Boolean      @default(false) @map("auto_approve")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  event     Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  locations EventSyncRuleLocation[]

  @@map("event_sync_rules")
}

model UserProviderAccount {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  provider              SyncProvider
  providerUserId        String       @map("provider_user_id")
  accessTokenEncrypted  String?      @map("access_token_encrypted")
  refreshTokenEncrypted String?      @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?    @map("token_expires_at")
  scope                 String?
  connectedAt           DateTime     @default(now()) @map("connected_at")
  disconnectedAt        DateTime?    @map("disconnected_at")

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalActivities ExternalActivity[]

  @@unique([userId, provider])
  @@unique([provider, providerUserId])
  @@map("user_provider_accounts")
}

model ExternalActivity {
  id                    String       @id @default(uuid()) @db.Uuid
  userProviderAccountId String       @map("user_provider_account_id") @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  provider              SyncProvider
  externalId            String       @map("external_id")
  activityType          String?      @map("activity_type")
  startedAt             DateTime     @map("started_at")
  elapsedSeconds        Int          @map("elapsed_seconds")
  distanceMeters        Int          @map("distance_meters")
  startLat              Float?       @map("start_lat")
  startLng              Float?       @map("start_lng")
  endLat                Float?       @map("end_lat")
  endLng                Float?       @map("end_lng")
  payloadJson           Json         @map("payload_json")
  ingestedAt            DateTime     @default(now()) @map("ingested_at")

  providerAccount UserProviderAccount @relation(fields: [userProviderAccountId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendances     EventAttendance[]

  @@unique([provider, externalId])
  @@index([userId, startedAt])
  @@map("external_activities")
}

model EventAttendance {
  id                 String           @id @default(uuid()) @db.Uuid
  eventId            String           @map("event_id") @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  externalActivityId String?          @map("external_activity_id") @db.Uuid
  status             AttendanceStatus @default(pending)
  source             AttendanceSource
  matchedAt          DateTime?        @map("matched_at")
  reviewedAt         DateTime?        @map("reviewed_at")
  reviewedById       String?          @map("reviewed_by") @db.Uuid
  rejectionReason    String?          @map("rejection_reason")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User              @relation("AttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  externalActivity ExternalActivity? @relation(fields: [externalActivityId], references: [id], onDelete: SetNull)
  reviewedBy       User?             @relation("AttendanceReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@index([userId])
  @@map("event_attendances")
}

model CityLocation {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  slug         String             @unique
  city         String
  lat          Float
  lng          Float
  radiusMeters Int?               @map("radius_meters")
  status       CityLocationStatus @default(active)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  syncRules       EventSyncRuleLocation[]
  recurrenceRules EventRecurrenceRuleLocation[] @relation("CityLocationRecurrenceRules")
  eventInterests  EventInterest[]
  paceGroups      LocationPaceGroup[]

  @@index([city])
  @@index([status])
  @@map("city_locations")
}

/// Pace-group offerings for a location used by regular weekly cityrnng
/// runs. Shown on event detail under each starting point. Pace is stored
/// as integer seconds-per-km so 5:30 → 330. Optional `pacerName` if a
/// specific pacer is leading the group.
model LocationPaceGroup {
  id               String   @id @default(uuid()) @db.Uuid
  locationId       String   @map("location_id") @db.Uuid
  distanceKm       Int      @map("distance_km")
  paceSecondsPerKm Int      @map("pace_seconds_per_km")
  pacerName        String?  @map("pacer_name")
  createdAt        DateTime @default(now()) @map("created_at")

  location CityLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, distanceKm, paceSecondsPerKm], map: "uq_location_pace_group")
  @@map("location_pace_groups")
}

/// Soft RSVP — "I'm coming". Captures intent (location chosen) but does not
/// affect attendance counting or points. Distance and pace are decided
/// on-site by the runner, not stored here.
///
/// `eventKey` is a string so the same model serves both UUID-keyed events
/// (explicit one-off / override Event rows) and materialized recurrence
/// occurrences with synthetic "rule:UUID:YYYY-MM-DD" ids — no DB row per
/// occurrence is required just for RSVP intent.
model EventInterest {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  eventKey    String              @map("event_key")
  locationId  String              @map("location_id") @db.Uuid
  status      EventInterestStatus @default(going)
  createdAt   DateTime            @default(now()) @map("created_at")
  cancelledAt DateTime?           @map("cancelled_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  location CityLocation @relation(fields: [locationId], references: [id])

  @@unique([userId, eventKey], map: "uq_user_event_interest")
  @@index([eventKey])
  @@map("event_interests")
}

model EventSyncRuleLocation {
  syncRuleId String   @map("sync_rule_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  syncRule EventSyncRule @relation(fields: [syncRuleId], references: [id], onDelete: Cascade)
  location CityLocation  @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@id([syncRuleId, locationId])
  @@index([locationId])
  @@map("event_sync_rule_locations")
}

model PointAccount {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @unique @map("user_id") @db.Uuid
  status    PointAccountStatus @default(active)
  balance   Int                @default(0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointTransaction[]

  @@map("point_accounts")
}

model PointTransaction {
  id             String                 @id @default(uuid()) @db.Uuid
  accountId      String                 @map("account_id") @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  direction      PointDirection
  amount         Int
  balanceAfter   Int                    @map("balance_after")
  status         PointTransactionStatus @default(posted)
  reasonType     PointReasonType        @map("reason_type")
  reasonRef      String?                @map("reason_ref")
  idempotencyKey String                 @unique @map("idempotency_key")
  comment        String?
  createdByType  PointActorType         @map("created_by_type")
  createdById    String?                @map("created_by_id") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at")

  account    PointAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  user       User         @relation("PointTransactionUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy  User?        @relation("PointTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  redemption Redemption?

  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([reasonType])
  @@map("point_transactions")
}

model Partner {
  id           String        @id @default(uuid()) @db.Uuid
  slug         String        @unique
  name         String
  description  String?
  contactEmail String?       @map("contact_email")
  status       PartnerStatus @default(active)
  createdById  String        @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  createdBy User            @relation("PartnerCreatedBy", fields: [createdById], references: [id])
  rewards   Reward[]
  members   PartnerMember[]

  @@index([status])
  @@map("partners")
}

/// Many-to-many between Partner and User: anyone in a partner's `members`
/// can verify codes for that partner via /partner. No internal role yet —
/// every member has the same capabilities. Granting "partner" role at the
/// User level is orthogonal: membership controls scope, role controls UI
/// access.
model PartnerMember {
  id          String   @id @default(uuid()) @db.Uuid
  partnerId   String   @map("partner_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by") @db.Uuid

  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user      User    @relation("PartnerMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("PartnerMemberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([partnerId, userId], map: "uq_partner_member")
  @@index([userId])
  @@map("partner_members")
}

model Reward {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique
  partnerId   String       @map("partner_id") @db.Uuid
  title       String
  description String?
  costPoints  Int          @map("cost_points")
  /// Optional badge text — "новинка", "до 31 мая", etc.
  badge       String?
  status      RewardStatus @default(active)
  validFrom   DateTime?    @map("valid_from")
  validUntil  DateTime?    @map("valid_until")
  /// Optional capacity limit (null = unlimited).
  capacity    Int?
  /// Counter incremented on each successful redemption.
  soldCount   Int          @default(0) @map("sold_count")
  createdById String       @map("created_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("RewardCreatedBy", fields: [createdById], references: [id])
  redemptions Redemption[]

  @@index([partnerId])
  @@index([status])
  @@map("rewards")
}

model Redemption {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  rewardId        String           @map("reward_id") @db.Uuid
  /// Snapshot of cost at the moment of redemption (reward.costPoints can change later).
  costPoints      Int              @map("cost_points")
  status          RedemptionStatus @default(active)
  /// 6-char alphanumeric uppercase, doubles as QR payload. Unique.
  code            String           @unique
  /// FK to the debit point_transactions row.
  pointTxnId      String           @unique @map("point_txn_id") @db.Uuid
  expiresAt       DateTime?        @map("expires_at")
  usedAt          DateTime?        @map("used_at")
  /// User (admin/partner) who marked it used — for audit.
  usedById        String?          @map("used_by_id") @db.Uuid
  cancelledAt     DateTime?        @map("cancelled_at")
  cancelledReason String?          @map("cancelled_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user             User             @relation("RedemptionUser", fields: [userId], references: [id], onDelete: Restrict)
  reward           Reward           @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  pointTransaction PointTransaction @relation(fields: [pointTxnId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt(sort: Desc)])
  @@index([rewardId, status])
  @@index([status, expiresAt])
  @@map("redemptions")
}

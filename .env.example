NODE_ENV=development

APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Server-side override — Next inside the web container fetches the API via
# the docker network instead of looping out through Caddy/Cloudflare.
# In staging/prod this is `http://api:4000/api/v1` (compose service name).
# Leave empty in dev where api runs on the host.
API_INTERNAL_URL=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cityrnng
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
SESSION_SECRET=change-me

S3_ENDPOINT=http://localhost:9000
S3_REGION=ru-central1
S3_BUCKET=cityrnng
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

EMAIL_FROM=noreply@cityrnng.local
EMAIL_PROVIDER_API_KEY=change-me

# === Observability (Phase 2) ===
# Server-side Sentry DSN for the API project (and Next server runtime).
# Empty = SDK is no-op.
SENTRY_DSN=
# Browser Sentry DSN — separate project so client and server events don't mix.
NEXT_PUBLIC_SENTRY_DSN=
# Tag events with environment (e.g. staging, production). Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Tracing sample rate (0..1). 0.1 = 10% of requests.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Auth token used at build time to upload source maps. Optional —
# without it the build still works, just no source maps in Sentry.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Pino log level: fatal, error, warn, info, debug, trace, silent.
LOG_LEVEL=info

POSTHOG_KEY=
YANDEX_METRICA_ID=

# Auth (Epic 1)
JWT_ACCESS_SECRET=replace-me-with-a-32+char-random-string
JWT_REFRESH_SECRET=replace-me-with-a-32+char-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
LOGIN_CHALLENGE_TTL_MINUTES=15
# When true, /auth/request-login returns the magic token in the response body.
# Use only in local development.
AUTH_DEV_RETURN_TOKEN=true

# Strava integration (Epic 3)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:4000/api/v1/integrations/strava/callback
STRAVA_SCOPES=read,activity:read
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Points engine (Epic 6)
WELCOME_BONUS_POINTS=100
# Fallback amounts used only when Event.isPointsEligible=true AND Event.basePointsAward=0.
EVENT_ATTENDANCE_REGULAR_POINTS_FALLBACK=0
EVENT_ATTENDANCE_SPECIAL_POINTS_FALLBACK=0
